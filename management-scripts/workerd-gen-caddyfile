#!/bin/bash
# /usr/local/bin/workerd-gen-caddyfile
# Generates /etc/caddy/Caddyfile from all workers' ports files.
# Applies transport tuning (keepalive, connection pooling) for performance.
# Combined with /etc/caddy/Caddyfile.manual for custom entries.

set -euo pipefail

CADDYFILE="/etc/caddy/Caddyfile"
WORKERS_DIR="/etc/workerd/workers"

# ── Global block ──────────────────────────────────────────────────
cat > "$CADDYFILE" << 'HEADER'
{
    admin localhost:2019
    log {
        output file /var/log/caddy/access.log {
            roll_size 100mb
            roll_keep 5
        }
        level WARN
    }
}

HEADER

# ── Per-worker domain blocks ─────────────────────────────────────
for worker_dir in "$WORKERS_DIR"/*/; do
    worker=$(basename "$worker_dir")
    ports_file="${worker_dir}/ports"
    [ -f "$ports_file" ] || continue

    port_count=$(wc -l < "$ports_file" | tr -d ' ')
    [ "$port_count" -eq 0 ] && continue

    # Build "localhost:8080 localhost:8081 ..." string
    ports=$(sed -E 's/([0-9]+)/localhost:\1/g' "$ports_file" | tr '\n' ' ' | sed 's/ $//')

    # Per-instance connection limits scale with port count
    max_conns=$(( 50 * port_count ))
    [ "$max_conns" -gt 200 ] && max_conns=200

    idle_conns=$(( 25 * port_count ))
    [ "$idle_conns" -gt 100 ] && idle_conns=100

    cat >> "$CADDYFILE" << BLOCK

# BEGIN workerd:${worker}
${worker}.yourdomain.com {
    reverse_proxy ${ports} {
        lb_policy       least_conn
        health_uri      /healthz
        health_interval 10s
        health_timeout  3s
        transport http {
            max_conns_per_host    ${max_conns}
            keepalive             30s
            keepalive_idle_conns  ${idle_conns}
            dial_timeout          5s
            response_header_timeout 30s
        }
    }
    tls your@email.com
}
# END workerd:${worker}
BLOCK
done

# ── Manual entries ────────────────────────────────────────────────
if [ -f /etc/caddy/Caddyfile.manual ]; then
    echo "" >> "$CADDYFILE"
    cat /etc/caddy/Caddyfile.manual >> "$CADDYFILE"
fi

echo "Caddyfile regenerated with connection pooling"
