#!/bin/bash
# /usr/local/bin/workerd-gen-nginx
# Generates /etc/nginx/sites-available/workerd from all workers' ports files.
set -euo pipefail

NGINX_CONF="/etc/nginx/sites-available/workerd"
WORKERS_DIR="/etc/workerd/workers"

{
cat << 'HEREDOC'
# workerd reverse proxy — generated by workerd-gen-nginx

HEREDOC

has_workers=false
for worker_dir in "$WORKERS_DIR"/*/; do
    worker=$(basename "$worker_dir")
    ports_file="${worker_dir}/ports"
    [ -f "$ports_file" ] || continue

    port_count=$(wc -l < "$ports_file" | tr -d ' ')
    [ "$port_count" -eq 0 ] && continue

    has_workers=true

    # Build server lines properly
    server_lines=""
    while IFS= read -r port; do
        [ -z "$port" ] && continue
        server_lines="${server_lines}        server 127.0.0.1:${port} max_fails=3 fail_timeout=10s weight=1;
"
    done < "$ports_file"

    cat << BLOCK

# workerd:${worker}
upstream workerd_${worker} {
    zone workerd_${worker}_upstream 64k;
    least_conn;
    keepalive 100;
${server_lines}}

server {
    listen 80;
    listen [::]:80;
    server_name ${worker}.localhost;

    location / {
        proxy_pass http://workerd_${worker};
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header Connection "";
        proxy_connect_timeout 5s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;
        proxy_next_upstream error timeout http_502 http_503 http_504;
        proxy_next_upstream_tries 3;
        proxy_next_upstream_timeout 10s;
    }

    location /healthz {
        proxy_pass http://workerd_${worker};
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_connect_timeout 2s;
        proxy_read_timeout 5s;
    }

    location /nginx_status {
        stub_status on;
        allow 127.0.0.1;
        deny all;
    }
}
BLOCK

done

if [ "$has_workers" = false ]; then
    echo "# No workers deployed yet"
fi

} > "$NGINX_CONF"

echo "✓ nginx config regenerated: $NGINX_CONF"